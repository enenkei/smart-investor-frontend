model company_overview {
  ticker             String    @id
  name               String?
  description        String?
  sector             String?
  industry           String?
  moving_average_50  String?
  moving_average_200 String?
  updated_at         DateTime? @default(now())
  dividend_per_share String?
  dividend_yield     String?
}

model fundamentals {
  ticker            String  @id
  sector            String?
  pe_ratio          Float?
  revenue_growth    Float?
  dividend_yield    Float?
  payout_ratio      Float?
  beta              Float?
  market_cap        Float?
  free_cash_flow    Float?
  roe               Float?
  de_ratio          Float?
  dividend_cagr_5y  Float?
  eps_growth_5y     Float?
  last_updated      String?
  operating_margins Float?
  ebitda            Float?
  current_ratio     Float?
}

model insider_transactions {
  id               Int       @id @default(autoincrement())
  ticker           String?
  executive        String?
  position         String?
  date             String?
  transaction_type String?
  shares_traded    String?
  price            String?
  updated_at       DateTime? @default(now())
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  role          Role      @default(USER)
  resetToken    String?   @unique
  resetTokenExp DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  avatarUrl     String?
  fullName      String?
  pseudo        String?
  sessionId     String?   @unique
  isActive      Boolean?  @default(false) @map("is_active")

  @@map("users")
}

model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  name        String?
  description String?
  value       String
  updatedAt   DateTime @updatedAt

  @@map("system_setting")
}

model commodities {
  commodity    String    @id
  name         String?
  data         Json?
  last_updated DateTime? @default(now())
  interval     String?
}

model index_data {
  symbol       String    @id
  name         String?
  data         Json?
  last_updated DateTime? @default(now())
}

enum Role {
  ADMIN
  USER
}

model portfolio_holdings {
  id                   Int       @id @default(autoincrement())
  cik                  String
  ticker               String
  cusip                String?
  shares_count         Float?
  position_value       Float?
  percent_of_portfolio Float?
  report_date          DateTime
  filed_at             DateTime?
  updated_at           DateTime  @default(now()) @updatedAt

  @@map("portfolio_holdings")
}

model strategies {
  slug                String   @id
  display_name        String
  tickers             String[]
  weights             Json
  expected_return     Float
  expected_volatility Float
  updated_at          DateTime @default(now()) @updatedAt
  mode                String

  @@map("strategies")
}

model investor_directory {
  cik            String   @id @unique
  display_name   String?
  legal_name     String?
  investor_type  String?  @default("Institutional")
  is_active      Boolean  @default(true)
  last_sync_date DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt

  @@map("investor_directory")
}

model user_portfolio {
  id          Int           @id @default(autoincrement())
  owner_id    Int
  owner_name  String?
  name        String?
  updated_at  DateTime      @updatedAt
  userAssets  user_assets[]
  projections Json
  metrics     Json

  @@unique([owner_id, name])
  @@map("user_portfolio")
}

model user_assets {
  id             Int            @id @default(autoincrement())
  symbol         String
  shares         Float?
  avg_cost_basis Float?
  weight         Float?
  owner_id       Int
  portfolio_id   Int
  owner_name     String?
  updated_at     DateTime       @updatedAt
  portfolio      user_portfolio @relation(fields: [portfolio_id], references: [id])

  @@unique([owner_id, portfolio_id, symbol])
  @@map("user_assets")
}

model watchlist {
  id         Int      @id @default(autoincrement())
  owner_id   Int
  owner_name String?
  symbol     String
  added_at   DateTime @default(now()) @updatedAt

  @@unique([owner_id, symbol])
  @@map("watchlist")
}
